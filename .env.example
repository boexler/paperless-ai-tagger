# Paperless-ngx API (for paperless-ngx-mcp via stdio)
PAPERLESS_BASE_URL=http://paperless:8000
PAPERLESS_API_TOKEN=your-paperless-api-token

# Agent provider: cursor | codex
AGENT_PROVIDER=cursor

# Cursor SDK (required when AGENT_PROVIDER=cursor)
CURSOR_API_KEY=cursor_your_api_key_here
CURSOR_MODEL=composer-2.5
# Model parameters as key:value pairs separated by commas (default: fast:false)
CURSOR_MODEL_PARAMS=fast:false
# Optional: log all available Cursor models and parameters at container startup
# CURSOR_LIST_MODELS_ON_STARTUP=true

# OpenAI Codex CLI (required when AGENT_PROVIDER=codex)
# CODEX_API_KEY=sk-your-openai-api-key
# CODEX_MODEL=gpt-5.4-mini
# CODEX_REASONING_EFFORT=low
# CODEX_MODEL_VERBOSITY=low
# CODEX_APPROVAL_POLICY=never
# CODEX_SANDBOX=workspace-write
# CODEX_NETWORK_ACCESS=true
# CODEX_COMMAND=codex
# CODEX_HOME=/data/codex

# Webhook receiver (stage NN -> port 808N)
WEBHOOK_SECRET=change-me-to-a-long-random-string
WEBHOOK_PORT_01=8081
WEBHOOK_PORT_02=8082
WEBHOOK_PORT_03=8083
LOG_LEVEL=INFO

# Optional: prompt template filename (resolved to /app/prompts/<name> in Docker)
# PROMPT_TEMPLATE=01-tag-document.md

# Optional: full path override (local development)
# PROMPT_TEMPLATE_PATH=../../prompts/01-tag-document.md

# Optional: path to paperless-ngx-mcp binary (default in Docker image)
# PAPERLESS_MCP_COMMAND=/usr/local/bin/paperless-ngx-mcp

# Optional: skip documents that were already processed (hours)
DEDUP_TTL_HOURS=24

# Optional: max parallel tagging jobs per instance (default: 1 = serial queue)
MAX_CONCURRENT_JOBS=1
